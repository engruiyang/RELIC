{
  "desktop_id": "relic_desktop_v1",
  "version": "26a.0",
  "mode": "desktop_preview",
  "status_bar": {
    "enabled": true,
    "locked": true,
    "position": "top",
    "height": 48,
    "widgets": [
      {
        "type": "status_light",
        "id": "connection_light",
        "label": "Connection",
        "source": "runtimeSnapshot.connection_status",
        "fallback": "unknown",
        "preset": "status_light"
      }
    ],
    "style": {
      "preset": "glass_card"
    }
  },
  "dock": {
    "enabled": true,
    "locked": true,
    "position": "left",
    "width": 220,
    "height": 780,
    "buttons": [
      {
        "type": "button",
        "id": "dock_safe_stop",
        "label": "Safe Stop",
        "action_id": "live.safe_stop",
        "args": {},
        "variant": "danger",
        "required": true,
        "enabled_when": "always",
        "confirm": true,
        "style": {
          "preset": "button_danger"
        }
      },
      {
        "type": "button",
        "id": "dock_refresh",
        "label": "Refresh",
        "action_id": "app.refresh_now",
        "args": {},
        "variant": "primary",
        "required": true,
        "enabled_when": "always",
        "confirm": false,
        "style": {
          "preset": "button_primary"
        }
      }
    ],
    "style": {
      "preset": "normal_card"
    }
  },
  "pages": [
    "home",
    "training",
    "calibration",
    "report",
    "diagnostics",
    "developer"
  ],
  "wallpaper": {
    "mode": "image",
    "asset_id": "background.app.main",
    "fallback_color": "#0f1720"
  }
}

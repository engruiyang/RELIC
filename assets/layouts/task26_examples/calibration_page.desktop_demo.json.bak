{
  "page_id": "calibration",
  "title": "Calibration Desktop",
  "subtitle": "TASK26G-3 Calibration desktop pilot",
  "layout": {
    "mode": "grid",
    "columns": 12,
    "rows": 8,
    "gap": 8,
    "padding": 8
  },
  "cards": [
    {
      "id": "calibration_status_card",
      "type": "calibration",
      "title": "Calibration Status",
      "subtitle": "Current calibration gate",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 1,
        "col_span": 4,
        "row_span": 3
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#162235",
        "background_opacity": 0.88,
        "border_color": "#5D8CFF",
        "border_width": 2,
        "corner_radius": 18,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#DDEEFF",
        "glass_opacity": 0.1,
        "glass_highlight": true
      },
      "widgets": [
        {
          "type": "metric",
          "id": "current_user",
          "label": "Current User",
          "source": "controlStateJson.current_user_id",
          "fallback": "none",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "calibration_status",
          "label": "Status",
          "source": "controlStateJson.calibration_status",
          "fallback": "unknown",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "calibration_usable",
          "label": "Usable",
          "source": "controlStateJson.calibration_usable",
          "fallback": "false",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "calibration_actions_card",
      "type": "actions",
      "title": "Calibration Actions",
      "subtitle": "Status, latest, list, bind",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 5,
        "row": 1,
        "col_span": 4,
        "row_span": 3
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#321B2B",
        "background_opacity": 0.88,
        "border_color": "#FF6680",
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#FFDDE8",
        "glass_opacity": 0.12,
        "glass_highlight": true
      },
      "widgets": [
        {
          "type": "button",
          "id": "calibration_status_btn",
          "label": "Calibration Status",
          "action_id": "calibration.status",
          "args": {},
          "variant": "primary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "calibration_latest_btn",
          "label": "Latest Calibration",
          "action_id": "calibration.latest",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "calibration_list_btn",
          "label": "List Calibrations",
          "action_id": "calibration.list",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "calibration_detail_card",
      "type": "detail",
      "title": "Calibration Detail",
      "subtitle": "Baseline and signal statistics",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 9,
        "row": 1,
        "col_span": 4,
        "row_span": 3
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#183326",
        "background_opacity": 0.82,
        "border_color": "#67E8A5",
        "border_width": 2,
        "corner_radius": 16,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": false,
        "glass_tint": "#DDEEFF",
        "glass_opacity": 0.1,
        "glass_highlight": false
      },
      "widgets": [
        {
          "type": "metric",
          "id": "last_calibration_id",
          "label": "Last Calibration",
          "source": "controlStateJson.last_calibration_id",
          "fallback": "none",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "attention_baseline",
          "label": "Attention Baseline",
          "source": "controlStateJson.attention_baseline",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "gyro_noise",
          "label": "Gyro Noise",
          "source": "controlStateJson.gyro_noise_rms",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "calibration_progress_card",
      "type": "progress",
      "title": "Calibration Progress",
      "subtitle": "Operator phase guidance",
      "required": false,
      "locked": false,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 4,
        "col_span": 8,
        "row_span": 3
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#221A33",
        "background_opacity": 0.74,
        "border_color": "#B58CFF",
        "border_width": 2,
        "corner_radius": 24,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#E8D7FF",
        "glass_opacity": 0.16,
        "glass_highlight": true
      },
      "widgets": [
        {
          "type": "metric",
          "id": "progress_status",
          "label": "Progress",
          "source": "controlStateJson.calibration_progress_status",
          "fallback": "idle",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "phase",
          "label": "Current Phase",
          "source": "controlStateJson.calibration_progress_phase",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "text_body",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "operator_hint",
          "label": "Operator Hint",
          "source": "controlStateJson.calibration_operator_guidance",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "text_body",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": true,
        "allow_collapse": true
      }
    }
  ]
}

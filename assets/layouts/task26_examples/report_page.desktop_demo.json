{
  "page_id": "report",
  "title": "Report Desktop",
  "subtitle": "TASK26 Report formal card page · current-user scoped list/show/export",
  "layout": {
    "mode": "grid",
    "columns": 12,
    "rows": 8,
    "gap": 8,
    "padding": 8
  },
  "cards": [
    {
      "id": "report_query_card",
      "type": "report_query",
      "title": "Report Query",
      "subtitle": "Current-user reports · one primary Show Selected action",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 1,
        "col_span": 4,
        "row_span": 8
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#182235",
        "background_opacity": 0.9,
        "border_color": "#6EE7F9",
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#CFFBFF",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 15,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 24,
        "button_height": 28,
        "widget_spacing": 5,
        "body_top_margin": 3,
        "feedback_height": 42,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3
      },
      "widgets": [
        {
          "type": "metric",
          "id": "report_current_user",
          "label": "Current User",
          "source": "controlStateJson.current_user_id",
          "fallback": "current user",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "select",
          "id": "report_selector",
          "label": "Report Selector",
          "options": [
            "no_report_available"
          ],
          "value": "no_report_available",
          "fallback": "no_report_available",
          "preset": "select_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "button",
          "id": "list_reports",
          "label": "Refresh Report List",
          "action_id": "report.list",
          "args": {},
          "variant": "secondary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "show_selected_report",
          "label": "Show Selected",
          "action_id": "report.show",
          "args": {
            "session_id": "${select.report_selector}"
          },
          "variant": "primary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "latest_report",
          "label": "Load Latest Report",
          "action_id": "report.latest",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "text",
          "id": "query_scope_note",
          "label": "Scope",
          "source": "",
          "fallback": "Current user only. Select a report from this list, then open it with the single Show Selected button.",
          "format": "plain",
          "unit": "",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": false,
        "allow_resize": false,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "report_detail_card",
      "type": "report_detail",
      "title": "Report Detail",
      "subtitle": "Selected report summary, wrapped paths and preview status",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 5,
        "row": 1,
        "col_span": 5,
        "row_span": 8
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#1B2234",
        "background_opacity": 0.9,
        "border_color": "#9BE7C0",
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#D7FFE8",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 15,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 24,
        "button_height": 28,
        "widget_spacing": 5,
        "body_top_margin": 3,
        "feedback_height": 42,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3
      },
      "widgets": [
        {
          "type": "metric",
          "id": "selected_session_id",
          "label": "Session ID",
          "source": "controlStateJson.report_selected_session_id",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "selected_report_user",
          "label": "Report User",
          "source": "controlStateJson.report_selected_user_id",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "report_available",
          "label": "Available",
          "source": "controlStateJson.report_available",
          "fallback": "false",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "selected_report_path",
          "label": "Report Path",
          "source": "controlStateJson.report_selected_report_path",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "export_path",
          "label": "Export Path",
          "source": "controlStateJson.report_export_path",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "preview_loaded",
          "label": "Preview Loaded",
          "source": "controlStateJson.report_preview_available",
          "fallback": "false",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "report_list_text",
          "label": "Current User Reports",
          "source": "controlStateJson.report_list_text",
          "fallback": "Click Refresh Report List to show report names.",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": false,
        "allow_resize": false,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "report_actions_card",
      "type": "actions",
      "title": "Report Actions",
      "subtitle": "Refresh, list and TXT export only",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 10,
        "row": 1,
        "col_span": 3,
        "row_span": 4
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#321B2B",
        "background_opacity": 0.9,
        "border_color": "#FF6680",
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#FFDDE8",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 14,
        "subtitle_pixel_size": 9,
        "widget_label_pixel_size": 9,
        "widget_value_pixel_size": 11,
        "widget_meta_pixel_size": 8,
        "widget_row_height": 22,
        "button_height": 26,
        "widget_spacing": 4,
        "body_top_margin": 2,
        "feedback_height": 34,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3
      },
      "widgets": [
        {
          "type": "metric",
          "id": "current_selected_session_id",
          "label": "Current Selection",
          "source": "controlStateJson.report_selected_session_id",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "button",
          "id": "refresh_report",
          "label": "Load Latest Report",
          "action_id": "report.latest",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "export_report_selected",
          "label": "Export Selected TXT",
          "action_id": "report.export_txt",
          "args": {
            "session_id": "${value.current_selected_session_id}"
          },
          "variant": "primary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "text",
          "id": "actions_note",
          "label": "Action Note",
          "source": "controlStateJson.last_action_message",
          "fallback": "Export writes a txt copy from the selected current-user report.",
          "format": "plain",
          "unit": "",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": false,
        "allow_resize": false,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "report_popup_card",
      "type": "report_popup",
      "title": "Report Popup / Preview",
      "subtitle": "Popup state and preview readiness",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 10,
        "row": 5,
        "col_span": 3,
        "row_span": 4
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#101722",
        "background_opacity": 0.9,
        "border_color": "#7C4DFF",
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#DACFFF",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 14,
        "subtitle_pixel_size": 9,
        "widget_label_pixel_size": 9,
        "widget_value_pixel_size": 11,
        "widget_meta_pixel_size": 8,
        "widget_row_height": 22,
        "button_height": 26,
        "widget_spacing": 4,
        "body_top_margin": 2,
        "feedback_height": 34,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3
      },
      "widgets": [
        {
          "type": "text",
          "id": "popup_hint",
          "label": "Popup Hint",
          "source": "controlStateJson.last_action_message",
          "fallback": "Show Selected, Latest Report or Export Selected TXT opens the detail popup.",
          "format": "plain",
          "unit": "",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "last_action_id",
          "label": "Last Action",
          "source": "controlStateJson.last_action_id",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "last_action_status",
          "label": "Action Status",
          "source": "controlStateJson.last_action_status",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "report_preview_available",
          "label": "Preview Loaded",
          "source": "controlStateJson.report_preview_available",
          "fallback": "false",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "popup_current_path",
          "label": "Current Path",
          "source": "controlStateJson.report_selected_report_path",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "popup_preview_text",
          "label": "Preview",
          "source": "controlStateJson.report_selected_report_preview",
          "fallback": "No report preview loaded yet.",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": false,
        "allow_resize": false,
        "allow_remove": false,
        "allow_collapse": true
      }
    }
  ]
}

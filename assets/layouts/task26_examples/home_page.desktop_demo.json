{
  "page_id": "home",
  "title": "Home Desktop",
  "subtitle": "TASK26A Desktop Demo",
  "layout": {
    "mode": "grid",
    "columns": 12,
    "rows": 8,
    "gap": 8,
    "padding": 10
  },
  "cards": [
    {
      "id": "runtime_io_card",
      "type": "runtime",
      "title": "Runtime I/O",
      "subtitle": "Connection and stream health",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 1,
        "col_span": 4,
        "row_span": 3
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#4A1F5C",
        "background_opacity": 0.62,
        "border_color": "#FFCC00",
        "border_width": 4,
        "corner_radius": 28,
        "shape_type": "rounded_rect",
        "background_image": "file:assets/packs/default/images/ui/buttons/button_primary.png",
        "glass_enabled": true,
        "glass_tint": "#FFF2B8",
        "glass_opacity": 0.22,
        "glass_highlight": true
      },
      "widgets": [
        {
          "type": "text",
          "id": "runtime_text",
          "label": "Runtime",
          "source": "runtimeSnapshot.connection_status",
          "fallback": "unknown",
          "format": "plain",
          "unit": "",
          "preset": "text_body",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "stream_alive",
          "label": "Stream",
          "source": "runtimeSnapshot.stream_alive",
          "fallback": "false",
          "format": "bool",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "attention_metric",
          "label": "Attention",
          "source": "runtimeSnapshot.attention",
          "fallback": "n/a",
          "format": "float_2",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "quick_actions_card",
      "type": "actions",
      "title": "Quick Actions",
      "subtitle": "Safety and refresh",
      "required": true,
      "locked": true,
      "preset": "danger_card",
      "position": {
        "col": 5,
        "row": 1,
        "col_span": 4,
        "row_span": 3
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#321B2B",
        "background_opacity": 0.88,
        "border_color": "#FF6680",
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "glass_enabled": true,
        "glass_tint": "#FFDDE8",
        "glass_opacity": 0.12,
        "glass_highlight": true
      },
      "widgets": [
        {
          "type": "button",
          "id": "refresh_btn",
          "label": "Refresh",
          "action_id": "app.refresh_now",
          "args": {},
          "variant": "primary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "safe_stop_btn",
          "label": "Safe Stop",
          "action_id": "live.safe_stop",
          "args": {},
          "variant": "danger",
          "required": true,
          "enabled_when": "always",
          "confirm": true,
          "style": {
            "preset": "button_danger"
          }
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "relic_identity_card",
      "type": "identity",
      "title": "RELIC Identity",
      "subtitle": "Brand and visual",
      "required": false,
      "locked": false,
      "preset": "image_card",
      "position": {
        "col": 6,
        "row": 2,
        "col_span": 4,
        "row_span": 2
      },
      "shape": "image_frame",
      "style": {
        "background_color": "#241E36",
        "background_opacity": 0.78,
        "border_color": "#C4B5FD",
        "border_width": 1,
        "corner_radius": 24,
        "shape_type": "pill",
        "glass_enabled": true,
        "glass_tint": "#F2ECFF",
        "glass_opacity": 0.16,
        "glass_highlight": true
      },
      "widgets": [
        {
          "type": "image",
          "id": "identity_image",
          "label": "Identity",
          "source": "renderResourcesJson.assets.ui.logo.main",
          "fallback": "asset:background.home.main",
          "format": "asset",
          "unit": "",
          "preset": "image_deco",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "identity_text",
          "label": "Tagline",
          "value": "RELIC / 意念玩家",
          "fallback": "RELIC",
          "format": "plain",
          "unit": "",
          "preset": "text_body",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": true,
        "allow_collapse": true
      }
    }
  ]
}
{
  "page_id": "training",
  "title": "Training Desktop",
  "subtitle": "TASK26F-0A Training migration audit demo",
  "layout": {
    "mode": "grid",
    "columns": 12,
    "rows": 8,
    "gap": 8,
    "padding": 10
  },
  "cards": [
    {
      "id": "training_control_card",
      "type": "actions",
      "title": "Training Controls",
      "subtitle": "Readiness, session, and safe stop actions",
      "required": true,
      "locked": true,
      "preset": "danger_card",
      "position": {
        "col": 1,
        "row": 1,
        "col_span": 4,
        "row_span": 2
      },
      "shape": "rounded_rect",
      "style": {},
      "widgets": [
        {
          "type": "button",
          "id": "start_session_btn",
          "label": "Start Session",
          "action_id": "session.start",
          "args": {},
          "variant": "primary",
          "required": true,
          "enabled_when": "readiness_ready",
          "confirm": true,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "stop_session_btn",
          "label": "Stop Session",
          "action_id": "session.stop",
          "args": {},
          "variant": "secondary",
          "required": true,
          "enabled_when": "always",
          "confirm": true,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "safe_stop_btn",
          "label": "Safe Stop",
          "action_id": "live.safe_stop",
          "args": {},
          "variant": "danger",
          "required": true,
          "enabled_when": "always",
          "confirm": true,
          "style": {
            "preset": "button_danger"
          }
        },
        {
          "type": "button",
          "id": "session_status_btn",
          "label": "Session Status",
          "action_id": "session.status",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "text",
          "id": "current_user_id_source",
          "label": "Current User",
          "source": "controlStateJson.current_user_id",
          "fallback": "none",
          "format": "plain",
          "unit": "",
          "preset": "text_body",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": false,
        "allow_resize": false,
        "allow_remove": false,
        "allow_collapse": false
      }
    },

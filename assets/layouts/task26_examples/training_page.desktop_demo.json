      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 5,
        "row": 1,
        "col_span": 4,
        "row_span": 2
      },
      "shape": "rounded_rect",
      "style": {},
      "widgets": [
        {
          "type": "metric",
          "id": "session_active",
          "label": "Active",
          "source": "sessionState.session_active",
          "fallback": "false",
          "format": "bool",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "current_session_id",
          "label": "Session ID",
          "source": "sessionState.current_session_id",
          "fallback": "none",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "session_elapsed_ms",
          "label": "Elapsed",
          "source": "sessionState.session_elapsed_ms",
          "fallback": "0",
          "format": "duration_ms",
          "unit": "ms",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": false,
        "allow_resize": false,
        "allow_remove": false,
        "allow_collapse": true

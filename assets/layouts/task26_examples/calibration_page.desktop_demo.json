{
  "page_id": "calibration",
  "title": "Calibration Desktop",
  "subtitle": "Formal calibration cards: control, feedback, query, popup detail",
  "layout": {
    "mode": "grid",
    "columns": 12,
    "rows": 12,
    "gap": 8,
    "padding": 8
  },
  "cards": [
    {
      "id": "calibration_control_card",
      "type": "actions",
      "title": "Calibration Control Panel",
      "subtitle": "Bind selected calibration and control calibration lifecycle",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 1,
        "col_span": 4,
        "row_span": 6
      },
      "shape": "rounded_rect",
      "style": {
        "background_opacity": 0.9,
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_opacity": 0.12,
        "glass_highlight": true,
        "title_pixel_size": 16,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 26,
        "button_height": 28,
        "widget_spacing": 4,
        "body_top_margin": 2,
        "feedback_height": 22,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 4,
        "background_color": "#261A31",
        "border_color": "#B479FF",
        "glass_tint": "#F2DDFF"
      },
      "widgets": [
        {
          "type": "select",
          "id": "selected_calibration_id",
          "label": "Bind Target",
          "value": "manual",
          "fallback": "manual",
          "options": [
            "manual"
          ],
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "button",
          "id": "bind_selected_calibration",
          "label": "Bind Selected",
          "action_id": "calibration.bind",
          "args": {
            "calibration_id": "${select.selected_calibration_id}"
          },
          "variant": "primary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "start_calibration",
          "label": "Start Calibration",
          "action_id": "calibration.start",
          "args": {},
          "variant": "primary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "poll_calibration_progress",
          "label": "Poll Progress",
          "action_id": "calibration.poll",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "cancel_calibration",
          "label": "Cancel Calibration",
          "action_id": "calibration.cancel",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "calibration_status_btn",
          "label": "Calibration Status",
          "action_id": "calibration.status",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "calibration_feedback_card",
      "type": "calibration_feedback",
      "title": "Calibration Feedback",
      "subtitle": "Finite calibration guidance: phase, elapsed/remain timer and current operator prompt",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 5,
        "row": 1,
        "col_span": 8,
        "row_span": 6
      },
      "shape": "rounded_rect",
      "style": {
        "background_opacity": 0.9,
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_opacity": 0.12,
        "glass_highlight": true,
        "title_pixel_size": 16,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 24,
        "button_height": 30,
        "widget_spacing": 3,
        "body_top_margin": 2,
        "feedback_height": 24,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 5,
        "background_color": "#102A30",
        "border_color": "#4FE3D2",
        "glass_tint": "#D9FFF7"
      },
      "widgets": [
        {
          "type": "metric",
          "id": "progress_running",
          "label": "Running",
          "source": "controlStateJson.calibration_progress_running",
          "fallback": "false",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "progress_phase",
          "label": "Phase",
          "source": "controlStateJson.calibration_progress_phase",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "elapsed_time",
          "label": "Elapsed",
          "source": "controlStateJson.calibration_progress_elapsed_sec",
          "fallback": "0.0",
          "format": "plain",
          "unit": "s",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "remaining_time",
          "label": "Remain",
          "source": "controlStateJson.calibration_phase_remaining_sec",
          "fallback": "0.0",
          "format": "plain",
          "unit": "s",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "progress_percent",
          "label": "Progress",
          "source": "controlStateJson.calibration_progress_percent",
          "fallback": "0.0",
          "format": "plain",
          "unit": "%",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "active_prompt",
          "label": "Current Guidance",
          "source": "controlStateJson.calibration_operator_guidance",
          "fallback": "Click Start Calibration to show step-by-step operator guidance.",
          "format": "plain",
          "unit": "",
          "preset": "text_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "calibration_query_card",
      "type": "query",
      "title": "Calibration Query",
      "subtitle": "Query current user's calibrations or manually paste calibration ID",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 7,
        "col_span": 12,
        "row_span": 5
      },
      "shape": "rounded_rect",
      "style": {
        "background_opacity": 0.9,
        "border_width": 2,
        "corner_radius": 20,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_opacity": 0.12,
        "glass_highlight": true,
        "title_pixel_size": 16,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 26,
        "button_height": 28,
        "widget_spacing": 4,
        "body_top_margin": 2,
        "feedback_height": 22,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 4,
        "background_color": "#1D2535",
        "border_color": "#5D8CFF",
        "glass_tint": "#DDEEFF"
      },
      "widgets": [
        {
          "type": "select",
          "id": "selected_calibration_id",
          "label": "Current User Calibration",
          "value": "manual",
          "fallback": "manual",
          "options": [
            "manual"
          ],
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "input",
          "id": "manual_calibration_id",
          "label": "Manual ID",
          "value": "",
          "fallback": "Paste calibration id",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "button",
          "id": "list_current_calibrations",
          "label": "List Current User",
          "action_id": "calibration.list",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "latest_calibration",
          "label": "Latest Calibration Detail",
          "action_id": "calibration.latest",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "show_selected_calibration",
          "label": "Show Selected",
          "action_id": "calibration.show",
          "args": {
            "calibration_id": "${select.selected_calibration_id}"
          },
          "variant": "primary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "show_manual_calibration",
          "label": "Show Manual",
          "action_id": "calibration.show",
          "args": {
            "calibration_id": "${input.manual_calibration_id}"
          },
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    }
  ]
}
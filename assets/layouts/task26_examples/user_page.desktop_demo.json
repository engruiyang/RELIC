{
  "page_id": "user",
  "title": "User Desktop",
  "subtitle": "TASK26G-3 User desktop pilot",
  "layout": {
    "mode": "grid",
    "columns": 12,
    "rows": 8,
    "gap": 8,
    "padding": 8
  },
  "cards": [
    {
      "id": "user_current_card",
      "type": "user",
      "title": "Current User",
      "subtitle": "Loaded user and profile gate",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 1,
        "col_span": 4,
        "row_span": 2
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#162235",
        "background_opacity": 0.88,
        "border_color": "#5D8CFF",
        "border_width": 2,
        "corner_radius": 18,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#DDEEFF",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 15,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 20,
        "button_height": 24,
        "widget_spacing": 3,
        "body_top_margin": 1,
        "feedback_height": 34,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3
      },
      "widgets": [
        {
          "type": "metric",
          "id": "current_user",
          "label": "Current User",
          "source": "controlStateJson.current_user_id",
          "fallback": "none",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "profile_loaded",
          "label": "Profile Loaded",
          "source": "controlStateJson.profile_loaded",
          "fallback": "false",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "metric",
          "id": "last_calibration",
          "label": "Last Calibration",
          "source": "controlStateJson.last_calibration_id",
          "fallback": "none",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "user_credentials_card",
      "type": "form",
      "title": "Register / Login",
      "subtitle": "Register: fill Register ID + Display Name. Login: fill Login ID, then Load/Profile.",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 5,
        "row": 1,
        "col_span": 4,
        "row_span": 4
      },
      "shape": "rounded_rect",
      "style": {
        "background_opacity": 0.88,
        "border_width": 2,
        "corner_radius": 18,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#DDEEFF",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 15,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 20,
        "button_height": 24,
        "widget_spacing": 3,
        "body_top_margin": 1,
        "feedback_height": 34,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3,
        "background_color": "#202640",
        "border_color": "#FFD479"
      },
      "widgets": [
        {
          "type": "input",
          "id": "new_user_id",
          "label": "Register ID",
          "value": "TEST_NEW",
          "fallback": "New user id, e.g. TEST_NEW",
          "required": true,
          "style": {}
        },
        {
          "type": "input",
          "id": "new_display_name",
          "label": "Display Name",
          "value": "TEST New User",
          "fallback": "Visible name for the new user",
          "required": false,
          "style": {}
        },
        {
          "type": "input",
          "id": "login_user_id",
          "label": "Login ID",
          "value": "TEST",
          "fallback": "Existing user id, e.g. TEST",
          "required": true,
          "style": {}
        },
        {
          "type": "button",
          "id": "register_user_btn",
          "label": "Register User",
          "action_id": "user.create",
          "args": {
            "user_id": "${input.new_user_id}",
            "display_name": "${input.new_display_name}"
          },
          "variant": "primary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "login_user_btn",
          "label": "Login / Load",
          "action_id": "user.load",
          "args": {
            "user_id": "${input.login_user_id}"
          },
          "variant": "secondary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "show_login_profile_btn",
          "label": "Show Login Profile",
          "action_id": "user.show_profile",
          "args": {
            "user_id": "${input.login_user_id}"
          },
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "user_selector_card",
      "type": "select",
      "title": "User Selector",
      "subtitle": "Choose user and inspect profile",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 9,
        "row": 1,
        "col_span": 4,
        "row_span": 3
      },
      "shape": "rounded_rect",
      "style": {
        "background_opacity": 0.88,
        "border_width": 2,
        "corner_radius": 18,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#DDEEFF",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 15,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 20,
        "button_height": 24,
        "widget_spacing": 3,
        "body_top_margin": 1,
        "feedback_height": 34,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3,
        "background_color": "#1B2C36",
        "border_color": "#66CCFF"
      },
      "widgets": [
        {
          "type": "select",
          "id": "selected_user_id",
          "label": "Select User",
          "options": [
            "TEST",
            "demo",
            "TEST1",
            "TEST2",
            "TEST3",
            "TEST_NEW"
          ],
          "value": "TEST",
          "fallback": "TEST",
          "required": true,
          "style": {}
        },
        {
          "type": "button",
          "id": "load_selected_user_btn",
          "label": "Load Selected",
          "action_id": "user.load",
          "args": {
            "user_id": "${select.selected_user_id}"
          },
          "variant": "primary",
          "required": true,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_primary"
          }
        },
        {
          "type": "button",
          "id": "show_selected_profile_btn",
          "label": "Show Selected Profile",
          "action_id": "user.show_profile",
          "args": {
            "user_id": "${select.selected_user_id}"
          },
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        },
        {
          "type": "button",
          "id": "refresh_user_list_btn",
          "label": "Refresh List",
          "action_id": "user.list",
          "args": {},
          "variant": "secondary",
          "required": false,
          "enabled_when": "always",
          "confirm": false,
          "style": {
            "preset": "button_secondary"
          }
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "user_profile_card",
      "type": "profile",
      "title": "Profile Detail",
      "subtitle": "Training thresholds and preferred game",
      "required": true,
      "locked": true,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 3,
        "col_span": 4,
        "row_span": 2
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#183326",
        "background_opacity": 0.88,
        "border_color": "#67E8A5",
        "border_width": 2,
        "corner_radius": 18,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#DDEEFF",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 15,
        "subtitle_pixel_size": 10,
        "widget_label_pixel_size": 10,
        "widget_value_pixel_size": 12,
        "widget_meta_pixel_size": 9,
        "widget_row_height": 20,
        "button_height": 24,
        "widget_spacing": 3,
        "body_top_margin": 1,
        "feedback_height": 34,
        "feedback_pixel_size": 9,
        "header_spacing": 1,
        "content_spacing": 3
      },
      "widgets": [
        {
          "type": "metric",
          "id": "attention_low",
          "label": "Attention Low",
          "source": "controlStateJson.attention_low_threshold",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"

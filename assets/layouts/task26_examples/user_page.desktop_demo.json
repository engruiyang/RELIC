      "widgets": [
        {
          "type": "text",
          "id": "note",
          "label": "Note",
          "source": "appState.user_note",
          "fallback": "User page desktop pilot",
          "format": "plain",
          "unit": "",
          "preset": "text_body",
          "style": {},
          "visible_when": "always"
        },
        {
          "type": "text",
          "id": "policy",
          "label": "Policy",
          "source": "renderResourcesJson.task26_user_layout_status",
          "fallback": "editable optional card",
          "format": "plain",
          "unit": "",
          "preset": "text_body",

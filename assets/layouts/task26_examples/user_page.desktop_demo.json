            "TEST1",
            "TEST2",
            "TEST3",
            "TEST_NEW"
          ],
          "value": "TEST",
          "fallback": "TEST",
          "required": false,
          "style": {}
        },
        {
          "type": "button",
          "id": "profile_popup_btn",

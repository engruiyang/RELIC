    {
      "id": "user_notes_card",
      "type": "decoration",
      "title": "User Notes",
      "subtitle": "Optional desktop note card",
      "required": false,
      "locked": false,
      "preset": "normal_card",
      "position": {
        "col": 1,
        "row": 7,
        "col_span": 12,
        "row_span": 2
      },
      "shape": "rounded_rect",
      "style": {
        "background_color": "#172033",
        "background_opacity": 0.88,
        "border_color": "#465A78",
        "border_width": 2,
        "corner_radius": 18,
        "shape_type": "rounded_rect",
        "background_image": "",
        "glass_enabled": true,
        "glass_tint": "#DDEEFF",
        "glass_opacity": 0.1,
        "glass_highlight": true,
        "title_pixel_size": 15,

        },
        {
          "type": "metric",
          "id": "preferred_game",
          "label": "Preferred Game",
          "source": "controlStateJson.preferred_game_id",
          "fallback": "n/a",
          "format": "plain",
          "unit": "",
          "preset": "metric_default",
          "style": {},
          "visible_when": "always"
        }
      ],
      "card_policy": {
        "allow_move": true,
        "allow_resize": true,
        "allow_remove": false,
        "allow_collapse": true
      }
    },
    {
      "id": "user_profile_popup_card",

{
  "game_id": "trace_lock",
  "display_name": "TraceLock Protocol",
  "subtitle": "Data Trace Tracking Protocol",
  "vendor": "Qilin Logic",
  "version": "0.1.0",
  "supported_inputs": ["pointer_click"],
  "supported_entities": ["target", "focus_zone", "progress_ring", "timer_bar"],
  "supported_effects": ["trace_seal", "lock_failed", "trace_drop", "combo_popup", "level_up", "level_down"],
  "default_difficulty": 1,
  "mouse_action_map": {
    "0": "target_primary",
    "1": "background",
    "2": "target_omitted",
    "3": "trace_seal",
    "4": "lock_failed"
  },
  "visual_keys": [
    "tracelock.target.marked_trace",
    "tracelock.target.burst_trace",
    "tracelock.target.unstable_trace",
    "tracelock.focus_zone.default",
    "tracelock.progress_ring.default",
    "tracelock.timer.round",
    "tracelock.effect.trace_seal",
    "tracelock.effect.lock_failed",
    "tracelock.effect.trace_drop",
    "tracelock.effect.combo_popup",
    "tracelock.effect.level_up",
    "tracelock.effect.level_down"
  ]
}
